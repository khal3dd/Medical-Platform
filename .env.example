# ============================================================
# Liver Care Chatbot - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit your real .env file to version control.

# --- OpenRouter API ---
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here

# --- OpenRouter Base URL (do not change unless using a proxy) ---
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- LLM Model ---
# Use any model available on OpenRouter in "provider/model" format.
# Examples:
#   anthropic/claude-3.5-haiku        (fast, affordable — recommended)
#   anthropic/claude-3.5-sonnet       (smarter, more expensive)
#   openai/gpt-4o-mini                (OpenAI alternative)
#   mistralai/mistral-7b-instruct     (open source, very cheap)
#   meta-llama/llama-3.1-8b-instruct  (open source, free tier)
#
# Full model list: https://openrouter.ai/models
LLM_MODEL=arcee-ai/trinity-large-preview:free

# --- LLM Parameters ---
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3

# --- App Settings ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# --- Session Settings ---
# Max number of conversation turns kept in memory per session
SESSION_MAX_TURNS=20
